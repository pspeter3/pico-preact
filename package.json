{
  "name": "pico-preact",
  "private": true,
  "description": "PicoCSS Preact Template",
  "homepage": "https://github.com/pspeter3/pico-preact#readme",
  "bugs": {
    "url": "https://github.com/pspeter3/pico-preact/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pspeter3/pico-preact.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "fix": "run-s fix:*",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt --write",
    "start": "vite",
    "test": "run-p test:*",
    "test:format": "oxfmt --check",
    "test:lint": "oxlint",
    "test:spec": "vitest run",
    "test:types": "tsc"
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1",
    "@tanstack/preact-query": "^5.93.0",
    "preact": "^10.28.4",
    "preact-iso": "^2.11.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.8.3",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
